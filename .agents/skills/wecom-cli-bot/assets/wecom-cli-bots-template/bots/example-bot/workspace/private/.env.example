# Copy this file to .env and fill values outside version control.
WECOM_BOT_ID=replace-with-wecom-bot-id
WECOM_BOT_SECRET=replace-with-wecom-bot-secret
MEMORY_API_URL=http://memory-service:8100
MEMORY_NAMESPACE=shared

# Kiro host-auth strategy:
# 1. Log in to Kiro CLI on the operator device.
# 2. Copy only the required Kiro auth/config directory to the Docker host.
# 3. Set KIRO_HOST_AUTH_DIR in the shell that runs docker compose.
# The compose file mounts this directory read-only at /host/kiro-auth.
# KIRO_HOST_AUTH_DIR=/absolute/placeholder/path/to/kiro-auth
