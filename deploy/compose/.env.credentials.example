# Generate a 32-byte base64 key with: openssl rand -base64 32
USER_CREDENTIALS_MASTER_KEY=replace-with-32-byte-base64-key

# Generate independent random tokens with: openssl rand -hex 32
USER_CREDENTIALS_INTERNAL_TOKEN=replace-with-internal-service-token
KIRO_RELAY_AUTH_TOKEN=replace-with-relay-token

# Must be reachable by the Enterprise WeChat user's browser.
CREDENTIAL_BIND_PUBLIC_URL=https://your-bot-domain.example.com
